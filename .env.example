# Configuración de Base de Datos (Supabase / Postgres)
# Formato: postgres://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgres://postgres:password@db.supabase.co:5432/postgres

# Seguridad
JWT_SECRET=tu_secreto_seguro_aqui

# Servidor
PORT=5000
NODE_ENV=production

# Email Config (Nodemailer - Gmail recomendado)
# Si usas Gmail, recuerda generar una "App Password"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_de_aplicacion

# Frontend URL (Para CORS y correos)
# Ejemplo: https://velora-app.vercel.app
FRONTEND_URL=http://localhost:3001

# Stripe Config (Opcional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
